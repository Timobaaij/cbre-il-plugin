{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CBRE I&L account-brief content plan (v8, scene / story-led)",
  "type": "object",
  "required": ["deck_meta", "slides"],
  "definitions": {
    "answer_id": {
      "type": "string",
      "description": "The answer-contract ids (reference/deck-structure.md). Tagging a slide/cell with an answer declares which contract question it lands; the spine gate asserts every REQUIRED answer is carried by a substantive slide. This is a content floor, not a template: slide count, order and layout stay composer-led.",
      "enum": ["bluf", "why-now", "company-profile", "strategy-priorities", "financial-story",
               "competitive-position", "company-challenges", "big-movers", "supply-chain-signature",
               "operating-model", "network-footprint", "challenge-to-real-estate", "property-setup",
               "recent-movements", "stakeholders-governance", "opportunity-intersection", "what-to-probe",
               "persona-ceo", "persona-csco", "persona-head-re"]
    }
  },
  "properties": {
    "deck_meta": {
      "type": "object",
      "required": ["target", "date", "prepared_by"],
      "properties": {
        "target": {"type": "string"},
        "subtitle": {"type": "string"},
        "audience": {"type": "string"},
        "date": {"type": "string"},
        "prepared_by": {"type": "string"},
        "meeting_context": {"type": "string"}
      }
    },
    "slides": {
      "type": "array",
      "minItems": 10,
      "description": "Story-led brief composed as scenes. No fixed template: the narrative outline decides the slides. A minimal spine (cover, references) plus chapters whose layout each slide composes from its own content. Slide count flexes; minItems guards against a degenerate plan.",
      "items": {
        "type": "object",
        "required": ["slide_no", "kind", "tone"],
        "properties": {
          "slide_no": {"type": ["integer", "string"]},
          "kind": {"type": "string", "enum": ["scene", "cover", "divider", "references"],
                   "description": "scene = a freely composed slide; cover/divider/references keep their fixed chrome"},
          "tone": {"type": "string", "enum": ["dark", "light"]},
          "eyebrow": {"type": "string", "description": "e.g. '03 | WHAT IS ON THE CEO'S MIND'"},
          "headline": {"type": "string", "description": "the serif claim; fits its own text"},
          "lead": {"type": "string", "description": "one-line so-what under the headline"},
          "footer": {"type": "string", "description": "source/as-of footnote"},
          "headline_size": {"type": "number"},
          "subtitle": {"type": "string", "description": "cover"},
          "contents": {"type": "array", "items": {"type": "string"}, "description": "cover 'what's inside' (up to 4)"},
          "number": {"type": ["integer", "string"], "description": "divider numeral"},
          "title": {"type": "string", "description": "divider title"},
          "items": {"type": "array", "items": {"type": "string"}, "description": "divider 'in this section' list"},
          "claim_ids": {"type": "array", "items": {"type": "string"}, "description": "sources the headline/lead"},
          "confidence": {"type": ["string", "null"], "enum": ["High", "Medium", "Low", null]},
          "answers": {"type": "array", "items": {"$ref": "#/definitions/answer_id"},
                      "description": "answer-contract ids this slide lands; the spine gate asserts every required answer is carried by a substantive slide/cell. Layout and count stay composer-led."},
          "scene": {
            "type": "array",
            "description": "ordered rows that fill the body by weight; each row splits into cells by span",
            "items": {
              "type": "object",
              "properties": {
                "weight": {"type": "number", "description": "relative vertical share of the body (default 1)"},
                "cells": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["kind"],
                    "properties": {
                      "kind": {"type": "string",
                        "enum": ["prose", "stat", "list", "table", "panel", "quote", "heading", "rule"]},
                      "span": {"type": "number", "description": "relative horizontal share of the row (default 1)"},
                      "text": {"type": "string", "description": "prose paragraph / quote text / heading text"},
                      "label": {"type": "string", "description": "prose lead-label or stat caption"},
                      "value": {"type": "string", "description": "stat hero value"},
                      "title": {"type": "string", "description": "panel title"},
                      "attrib": {"type": "string", "description": "quote attribution"},
                      "numbered": {"type": "boolean", "description": "list numbering"},
                      "uppercase": {"type": "boolean"},
                      "max_size": {"type": "number"},
                      "font_size": {"type": "number"},
                      "size": {"type": "number"},
                      "items": {"type": "array", "items": {"type": "object",
                        "properties": {"title": {"type": "string"}, "text": {"type": "string"},
                                       "label": {"type": "string"}, "value": {"type": "string"}}},
                        "description": "list items {title,text} or panel items {label,value}"},
                      "headers": {"type": "array", "items": {"type": "string"}},
                      "rows": {"type": "array", "items": {"type": "array", "items": {"type": "string"}}},
                      "aligns": {"type": "array", "items": {"type": "string"}},
                      "claim_ids": {"type": "array", "items": {"type": "string"}},
                      "confidence": {"type": ["string", "null"], "enum": ["High", "Medium", "Low", null]},
                      "answers": {"type": "array", "items": {"$ref": "#/definitions/answer_id"},
                                  "description": "answer-contract ids carried by this cell (see slide-level answers)"}
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
