"""Mechanical gate checks for the CBRE I&L account-brief pipeline (v6).

The DETERMINISTIC halves of the gates. The JUDGEMENT halves run as isolated
sub-agents (reference/gates.md); each writes a verdict file to
intermediate/reviews/<gate>.md, and `reviews` below asserts those exist so the
gate system cannot pass without the reviewers having run.

Subcommands (v8, scene model):
  validate-plan content_plan.json schema.json -> schema/structural validity (cheapest gate)
  self-check    schema.json build_deck.py      -> doc/code drift (slide kinds, cell kinds)
  qa1           content_plan.json ledger.csv   -> every headline + content cell cites a verified Claim ID; bands
  qa2           content_plan.json              -> evidence & honesty (no evaluative cell stated as fact)
  density       content_plan.json              -> scene has content, prose not a fragment, cover+references present
  personas      content_plan.json              -> the three mandatory persona slides (CEO/CSCO/Head of RE) are present
  spine         content_plan.json              -> answer contract: every required answer is carried by a substantive slide
  qa3           content_plan.json worklog.md   -> forecast re-derivation when the module is on (anti-patterns + sector band); passes when off
  reconcile     content_plan.json deck_text ledger -> no new claims/numbers on a slide vs the plan
  qa4           deck_text.txt                  -> em/en-dash sweep

deck_text is build_deck's `deck_text.txt` (written beside build_report.json on every
build, or regenerated with `build_deck.py --dump-text <pptx> <out.txt>`).
  reviews       <dir> {1|2}                    -> independent-reviewer verdict files present + not a blocking VERDICT: line
"""
from __future__ import annotations

import argparse
import ast
import csv
import json
import re
import sys
from pathlib import Path
from typing import List

# Scene-cell kinds that carry sourced content (must cite a Claim ID when populated).
CONTENT_KINDS = ("prose", "stat", "list", "table", "panel", "quote")
# Evaluative cell kinds (a read/claim stated as text) - never unsourced.
EVAL_KINDS = ("prose", "stat", "quote")

# ---- The answer contract (reference/deck-structure.md) ----
# The questions every brief must land. Checked as CONTENT, never as a fixed template:
# an answer is satisfied when it is tagged (slide- or cell-level `answers`) on at least
# one SUBSTANTIVE slide/cell. Slide count, order and layout stay composer-led, and G0/G4
# judge whether each answer is actually said well. The three persona answers are asserted
# by personas() (text-detected); spine() covers the rest.
REQUIRED_ANSWERS = (
    "bluf", "company-profile", "strategy-priorities", "financial-story",
    "big-movers", "supply-chain-signature", "operating-model", "network-footprint",
    "challenge-to-real-estate", "property-setup", "recent-movements",
    "stakeholders-governance", "opportunity-intersection", "what-to-probe",
)
# Strongly recommended but not script-blocked: the story may justify the omission, and
# G0/G4 adjudicate. spine() prints these as an advisory when absent.
EXPECTED_ANSWERS = ("why-now", "competitive-position", "company-challenges")
# Asserted by personas() (text-detected), listed here so a persona tag is a known id.
PERSONA_ANSWERS = ("persona-ceo", "persona-csco", "persona-head-re")
ALL_ANSWERS = REQUIRED_ANSWERS + EXPECTED_ANSWERS + PERSONA_ANSWERS

GATE_REVIEWS = {"1": ["G0", "G1b", "G2", "G4"], "2": ["G6b", "G7", "G8"]}
_VERDICT_TOKENS = re.compile(r"(?i)\b(verdict|green|amber|red|pass|fail|ship|fix-required|"
                             r"thin|clean|HIGH|MED|LOW|no open high|routed)\b")
# A reviewer records its bottom line on an explicit, machine-read VERDICT: line
# (mirroring the scorecard STATUS: contract). If that line reports a BLOCKING
# outcome, the gate cannot reach ALL-PASS however the orchestrator filled the
# scorecard: the orchestrator may not self-certify over a reviewer that blocked.
# A re-run after a fix overwrites the file with the FRESH reviewer's verdict, so
# a passing line is always the latest reviewer's word (reference/gates.md).
_VERDICT_LINE = re.compile(r"(?im)^\s*VERDICT:\s*(.+?)\s*$")
# A blocking outcome is recognised by the LEADING token of the verdict text. The
# convention is that the outcome word comes first ("VERDICT: RED ...", "VERDICT:
# BLOCKED", "VERDICT: fix-required"), so anchoring to the start is both sufficient
# and robust. This replaces the old anywhere-match-with-negation-lookbehind, which
# falsely tripped on clear prose such as "VERDICT: GREEN, nothing to reject" (the
# "to reject" was not guarded by the "no "/"not " lookbehind). "open HIGH" is
# deliberately absent: "no open HIGH" is itself a CLEAR, so a reviewer still
# holding one records its line as BLOCKED / fix-required per the convention.
_BLOCKING_VERDICT = re.compile(r"(?i)^\s*(red|block(?:ed)?|fix[- ]?required|reject(?:ed|s)?)\b")


def _load_plan(path: str) -> dict:
    return json.loads(Path(path).read_text(encoding="utf-8"))


def _iter_cells(plan: dict):
    """Yield (slide, cell) over every scene cell in the plan."""
    for s in plan.get("slides", []):
        for r in s.get("scene", []) or []:
            for c in r.get("cells", []) or []:
                yield s, c


def _cell_has_content(c: dict) -> bool:
    return bool((c.get("text") or "").strip() or (c.get("value") or "").strip()
                or c.get("items") or c.get("rows"))


def _load_ledger(path: str) -> dict:
    rows = {}
    with open(path, newline="", encoding="utf-8-sig") as f:
        for r in csv.DictReader(f):
            rows[(r.get("claim_id") or "").strip()] = r
    return rows


# ---- validate-plan (cheapest gate; schema if jsonschema available, else structural) ----

def validate_plan(plan_path: str, schema_path: str) -> List[str]:
    defects: List[str] = []
    try:
        plan = _load_plan(plan_path)
    except Exception as e:  # noqa
        return [f"content_plan.json does not parse: {e}"]
    schema = json.loads(Path(schema_path).read_text(encoding="utf-8"))
    try:
        import jsonschema  # type: ignore
        v = jsonschema.Draft7Validator(schema)
        for err in sorted(v.iter_errors(plan), key=lambda e: e.path):
            loc = "/".join(str(p) for p in err.path) or "(root)"
            defects.append(f"schema: {loc}: {err.message}")
        return defects
    except ImportError:
        pass
    # Structural fallback (no jsonschema installed).
    sp = schema["properties"]["slides"]
    kind_enum = set(sp["items"]["properties"]["kind"]["enum"])
    min_items = sp.get("minItems", 0)
    dm = plan.get("deck_meta", {})
    for k in ("target", "date", "prepared_by"):
        if not dm.get(k):
            defects.append(f"deck_meta missing required '{k}'")
    slides = plan.get("slides", [])
    if len(slides) < min_items:
        defects.append(f"slides: {len(slides)} entries, schema requires >= {min_items}")
    for s in slides:
        no = s.get("slide_no", "?")
        if s.get("kind", "scene") not in kind_enum:
            defects.append(f"slide {no}: kind '{s.get('kind')}' not in {sorted(kind_enum)}")
        if s.get("tone") not in ("dark", "light"):
            defects.append(f"slide {no}: tone '{s.get('tone')}' not dark/light")
    return defects


# ---- self-check (doc/code drift) ----

def _extract_from_build_deck(path: str):
    """Parse build_deck.py for the KIND and CELL dict keys (slide kinds and cell
    kinds) without importing, so the check runs even where the render library is absent."""
    tree = ast.parse(Path(path).read_text(encoding="utf-8"))
    kinds, cells = set(), set()
    for node in ast.walk(tree):
        if isinstance(node, ast.Assign):
            for t in node.targets:
                if isinstance(t, ast.Name) and t.id in ("KIND", "CELL") and isinstance(node.value, ast.Dict):
                    target = kinds if t.id == "KIND" else cells
                    for k in node.value.keys:
                        if isinstance(k, ast.Constant):
                            target.add(k.value)
    return kinds, cells


def self_check(schema_path: str, build_deck_path: str) -> List[str]:
    """Keep the schema and the renderer in lock-step: every slide kind and cell kind
    in the schema must be built by build_deck (KIND / CELL), and vice versa."""
    defects: List[str] = []
    schema = json.loads(Path(schema_path).read_text(encoding="utf-8"))
    sp = schema["properties"]["slides"]["items"]["properties"]
    schema_kinds = set(sp["kind"]["enum"])
    schema_cells = set(sp["scene"]["items"]["properties"]["cells"]["items"]["properties"]["kind"]["enum"])
    kinds, cells = _extract_from_build_deck(build_deck_path)
    if schema_kinds != kinds:
        if schema_kinds - kinds:
            defects.append(f"slide kinds in schema but not built by build_deck.KIND: {sorted(schema_kinds - kinds)}")
        if kinds - schema_kinds:
            defects.append(f"slide kinds built but not in schema enum: {sorted(kinds - schema_kinds)}")
    if schema_cells != cells:
        if schema_cells - cells:
            defects.append(f"cell kinds in schema but not built by build_deck.CELL: {sorted(schema_cells - cells)}")
        if cells - schema_cells:
            defects.append(f"cell kinds built but not in schema enum: {sorted(cells - schema_cells)}")
    return defects


def _check_source(where, cids, conf, ledger, defects):
    """The Evidence Standard, unchanged: a sourced element cites at least one
    resolving, verified, slide-mapped Claim ID and carries a confidence band."""
    if not cids:
        defects.append(f"{where}: cites no claim_ids (claim stated without a source)")
        return
    for cid in cids:
        row = ledger.get(cid)
        if row is None:
            defects.append(f"{where}: claim_id '{cid}' not found in ledger")
            continue
        for col in ("source_url", "source_tier", "retrieved_date"):
            if not (row.get(col) or "").strip():
                defects.append(f"{where}: ledger row '{cid}' missing {col}")
        if (row.get("verified") or "").strip().lower() == "no":
            defects.append(f"{where}: cites struck claim '{cid}' (verified=no)")
        elif not (row.get("slide") or "").strip():
            defects.append(f"{where}: cited row '{cid}' has a blank ledger 'slide' "
                           "(derive it from the plan; else it drops off the references slide)")
    if not conf:
        defects.append(f"{where}: missing confidence band")


def qa1(plan_path: str, ledger_path: str) -> List[str]:
    defects: List[str] = []
    plan = _load_plan(plan_path)
    ledger = _load_ledger(ledger_path)
    for s in plan.get("slides", []):
        no = s.get("slide_no", "?")
        # The slide-level serif headline IS a claim, so a scene headline must be sourced.
        if s.get("kind", "scene") == "scene" and (s.get("headline") or "").strip():
            _check_source(f"slide {no} headline", s.get("claim_ids") or [], s.get("confidence"), ledger, defects)
        for r in s.get("scene", []) or []:
            for c in r.get("cells", []) or []:
                if c.get("kind") in CONTENT_KINDS and _cell_has_content(c):
                    _check_source(f"slide {no} {c.get('kind')} cell", c.get("claim_ids") or [],
                                  c.get("confidence"), ledger, defects)
    for cid, row in ledger.items():
        if (row.get("verified") or "").lower() != "no":
            if not (row.get("confidence_band") or "").strip():
                defects.append(f"ledger '{cid}': missing confidence_band")
            if not (row.get("binding_test") or "").strip():
                defects.append(f"ledger '{cid}': missing binding_test")
    return defects


def qa2(plan_path: str) -> List[str]:
    """Evidence and honesty (mechanical slice): no evaluative claim stated as fact
    without a Claim ID. An evaluative cell is prose, a hero stat or a pull-quote."""
    defects: List[str] = []
    plan = _load_plan(plan_path)
    for s, c in _iter_cells(plan):
        no = s.get("slide_no", "?")
        if c.get("kind") in EVAL_KINDS and _cell_has_content(c) and not (c.get("claim_ids")):
            defects.append(f"slide {no} {c.get('kind')} cell: evaluative content has no Claim ID "
                           "(read or recommendation stated as fact?)")
    return defects


def density(plan_path: str) -> List[str]:
    """Density proxy on the plan (the true whitespace check is the visual gate G7).
    Asserts: every scene slide has content; prose cells are full paragraphs, not
    fragments; table rows have no empty cells; the deck carries cover + references.
    Filling the slide with substance is the authoring discipline and the visual gate."""
    defects: List[str] = []
    plan = _load_plan(plan_path)
    for s in plan.get("slides", []):
        if s.get("kind", "scene") != "scene":
            continue
        no = s.get("slide_no", "?")
        cells = [c for r in s.get("scene", []) or [] for c in r.get("cells", []) or []]
        content = [c for c in cells if c.get("kind") in CONTENT_KINDS and _cell_has_content(c)]
        if not content:
            defects.append(f"slide {no} (scene): no content cells (sparse/empty)")
            continue
        for c in cells:
            if c.get("kind") == "prose" and len((c.get("text") or "").strip()) < 60:
                defects.append(f"slide {no} prose cell: paragraph too short "
                               "(explain in full sentences, not a fragment)")
            if c.get("kind") == "table":
                for ri, row in enumerate(c.get("rows", []) or []):
                    if any(not str(cell).strip() for cell in row):
                        defects.append(f"slide {no} table: row {ri + 1} has an empty cell")
    kinds = [s.get("kind", "scene") for s in plan.get("slides", [])]
    if "cover" not in kinds:
        defects.append("deck: no cover slide")
    if "references" not in kinds:
        defects.append("deck: no references slide")
    return defects


def qa3(plan_path: str, worklog_path: str) -> List[str]:
    """G3 forecast re-derivation (the Script half). Passes trivially when the
    optional forecast module is OFF (deck_meta.forecast_module falsey). When ON, it
    re-derives every forecast from its SOURCED inputs with forecasting.run_forecast
    and FAILS on: a missing inputs file, an input with no Claim IDs, any of the five
    forecasting anti-patterns, or a current ratio outside its sector band. The
    inputs live in forecast_inputs.json beside forecasting_worklog.md (see
    reference/opportunity-classification.md)."""
    defects: List[str] = []
    try:
        plan = _load_plan(plan_path)
    except Exception as e:  # noqa
        return [f"content_plan.json does not parse: {e}"]
    if not plan.get("deck_meta", {}).get("forecast_module"):
        return []  # module off: nothing to re-derive
    import forecasting  # sibling helper; only imported when the module is on
    inputs_path = Path(worklog_path).with_name("forecast_inputs.json")
    if not inputs_path.exists():
        return [f"forecast module is on but {inputs_path.name} (the sourced forecast "
                "inputs) is missing; G3 cannot re-derive the math"]
    try:
        data = json.loads(inputs_path.read_text(encoding="utf-8"))
    except Exception as e:  # noqa
        return [f"{inputs_path.name} does not parse: {e}"]
    for fc in (data if isinstance(data, list) else [data]):
        key = fc.get("key", "?")
        if not fc.get("input_claim_ids"):
            defects.append(f"forecast '{key}': no input_claim_ids (every forecast input must be sourced)")
        try:
            res = forecasting.run_forecast(fc)
        except Exception as e:  # noqa
            defects.append(f"forecast '{key}': cannot compute ({e})")
            continue
        for flag in res.get("anti_pattern_flags", []):
            defects.append(f"forecast '{key}': {flag}")
        if res.get("plausibility_in_band") is False:
            defects.append(f"forecast '{key}': current ratio {res.get('current_ratio')} is OUTSIDE its "
                           f"sector band {res.get('sector_band')} (publish at Low confidence with the "
                           "deviation noted, or fix the input error)")
    return defects


_NUM = re.compile(r"\d")
_TOKENS = re.compile(r"[a-z0-9%€$£]+")
_NUMTOK = re.compile(r"\d[\d.,]*")
# A references-slide row as build_deck renders it: "[N] domain  (tier T, date)".
_REF_LINE = re.compile(r"^\s*\[\d+\]\s+\S+.*\(tier\s*\d", re.IGNORECASE)
# Library chrome present on every slide (the copyright footer and the CBRE
# wordmark); deterministic, not a plan claim, so reconcile skips it, the same
# class of exclusion already applied to the ledger-derived references rows.
_CHROME_LINE = re.compile(r"(?i)(confidential\s*&?\s*proprietary|\(c\)\s*\d{4}\s*cbre|^\s*cbre\s*$)")
# A line that is ONLY a short integer is a renderer-injected ordinal (the list /
# cover-contents / divider numbering build_deck draws as standalone shapes, e.g.
# "01", "02", "1"), not a plan claim. The renderer only ever emits plan strings
# plus these ordinals, so any standalone short integer is chrome, never a
# fabricated fact; excluding it lets reconcile flag genuine new numbers (including
# single digits embedded in a sentence, e.g. "7 DCs") without false positives.
_ORDINAL_LINE = re.compile(r"^\d{1,2}$")


def _bag(text: str) -> set:
    return set(_TOKENS.findall(text.lower()))


def _cell_text(c: dict) -> str:
    """All rendered text a scene cell contributes (paragraph, value, label, title,
    attribution, list/panel items, table headers and rows), so reconcile counts
    every rendered number/word as 'in the plan'."""
    parts = [c.get("text") or "", c.get("value") or "", c.get("label") or "",
             c.get("title") or "", c.get("attrib") or ""]
    for it in c.get("items", []) or []:
        parts += [it.get("title") or "", it.get("text") or "", it.get("label") or "", it.get("value") or ""]
    parts += [str(z) for z in (c.get("headers") or [])]
    for row in c.get("rows", []) or []:
        parts += [str(z) for z in row]
    return " ".join(parts)


def _slide_strings(plan: dict) -> List[str]:
    """Rendered text that lives on the slide but not in a cell: deck_meta, and each
    slide's eyebrow/headline/lead/footer/title/subtitle, divider number, and the
    cover contents / divider items lists."""
    out: List[str] = []
    dm = plan.get("deck_meta", {})
    for k in ("date", "subtitle", "target", "audience", "meeting_context"):
        if dm.get(k):
            out.append(str(dm[k]))
    for s in plan.get("slides", []):
        for k in ("eyebrow", "headline", "lead", "footer", "title", "subtitle"):
            if s.get(k):
                out.append(str(s[k]))
        if s.get("number") is not None:
            out.append(str(s["number"]))
        for k in ("items", "contents"):
            for v in (s.get(k) or []):
                out.append(str(v))
    return out


def reconcile(plan_path: str, deck_text_path: str, ledger_path: str) -> List[str]:
    defects: List[str] = []
    plan = _load_plan(plan_path)
    slide_level = " ".join(_slide_strings(plan))
    cell_texts = [_cell_text(c) for _, c in _iter_cells(plan)]
    plan_text = (" ".join(cell_texts) + " " + slide_level).lower()
    plan_bags = [(_bag(t), "cell") for t in cell_texts]
    plan_bags.append((_bag(slide_level), "(slide-level: headline/lead/eyebrow/cover/divider)"))
    plan_nums = set(_NUMTOK.findall(plan_text))
    deck = Path(deck_text_path).read_text(encoding="utf-8")
    # The references slide renders [1]..[k] for the k DE-DUPLICATED reference lines
    # (one per host/tier/date); those markers are legitimate. Use the SAME canonical
    # list build_deck renders, so the expected marker count matches the slide exactly
    # (un-deduped counting would over-count and could miss a real drift). Inline
    # markers are off, so no other [N] is expected.
    from ledger import reference_rows
    n_refs = len(reference_rows(ledger_path)) if ledger_path else 0
    plan_markers = {str(i) for i in range(1, n_refs + 1)}
    for m in re.findall(r"\[(\d+)\]", deck):
        if plan_markers and m not in plan_markers:
            defects.append(f"citation drift: deck uses [{m}] not in the content plan")
    # Every number on a deck line must exist somewhere in the plan (claim-level, not
    # line overlap). Skip references-slide lines: their tier/date numbers are
    # ledger-derived (build_deck renders "[N] domain (tier T, <pub_date>)"), not plan
    # claims, so a source pub-date such as 2023-09-30 must not raise a spurious 'new
    # number' and block G5 on a clean deck. This mirrors the _REF_LINE skip in the
    # line-overlap heuristic below; the references markers are audited separately.
    non_ref = " ".join(
        ls for ls in (l.strip() for l in deck.splitlines())
        if ls and not _REF_LINE.match(ls) and not _CHROME_LINE.search(ls)
        and not _ORDINAL_LINE.match(ls)).lower()
    for ntok in set(_NUMTOK.findall(non_ref)):
        # No blanket single-digit skip: a fabricated small number ("7 DCs", "3
        # regions") embedded in a sentence must still be caught. Renderer ordinals
        # are already excluded above as standalone _ORDINAL_LINE lines.
        if ntok not in plan_nums and ntok.rstrip(".,") not in plan_nums:
            defects.append(f"possible new number on deck not in the plan: '{ntok}'")
    # Line-overlap heuristic as a secondary signal.
    for line in deck.splitlines():
        line = line.strip()
        if len(line) < 8 or not _NUM.search(line):
            continue
        # The references slide is generated from the ledger, not from plan element
        # text, so its rows ("[N] domain (tier T, date)") never match a plan bag;
        # they are audited by the citation-marker check above and by being
        # ledger-derived, so skip them here rather than raise a false new-claim.
        if _REF_LINE.match(line) or _CHROME_LINE.search(line):
            continue
        lb = _bag(line)
        if not lb:
            continue
        best = max((len(lb & pb) / max(1, len(lb)) for pb, _ in plan_bags), default=0.0)
        if best < 0.5:
            defects.append(f"possible new claim on deck (no plan match >=50% tokens): \"{line[:90]}\"")
    return defects


def qa4(deck_text_path: str) -> List[str]:
    defects: List[str] = []
    text = Path(deck_text_path).read_text(encoding="utf-8")
    for i, line in enumerate(text.splitlines(), start=1):
        if "—" in line or "–" in line:
            defects.append(f"line {i}: contains an em/en dash -> \"{line.strip()[:80]}\"")
    return defects


def reviews(dirpath: str, gate: str) -> List[str]:
    """Assert the independent reviewers for a gate actually ran, by requiring a
    non-empty verdict file per required gate in <dir>/intermediate/reviews/."""
    defects: List[str] = []
    inter = Path(dirpath) / "intermediate"
    rdir = inter / "reviews"
    required = list(GATE_REVIEWS.get(gate, []))
    if gate == "1":
        try:
            plan = _load_plan(str(inter / "content_plan.json"))
            if plan.get("deck_meta", {}).get("forecast_module"):
                required.append("G3")
        except Exception:  # noqa
            pass
    for g in required:
        f = rdir / f"{g}.md"
        if not f.exists():
            defects.append(f"missing reviewer verdict file: intermediate/reviews/{g}.md (was {g} dispatched?)")
            continue
        txt = f.read_text(encoding="utf-8").strip()
        if len(txt) < 20:
            defects.append(f"reviews/{g}.md is empty/stub; the {g} reviewer must record its verdict")
            continue
        if not _VERDICT_TOKENS.search(txt):
            defects.append(f"reviews/{g}.md carries no recognisable verdict token")
        # If the reviewer left an explicit VERDICT: line and it is a block, the
        # gate must not pass over it (the scorecard cannot self-certify a clear).
        m = _VERDICT_LINE.search(txt)
        if m and _BLOCKING_VERDICT.search(m.group(1)):
            defects.append(f"reviews/{g}.md records a BLOCKING verdict ('{m.group(1).strip()[:60]}'); "
                           "re-run a fresh reviewer and clear it before ALL-PASS")
    return defects


def coverage(plan_path: str, ledger_path: str) -> List[str]:
    """The depth pass aid: list the VALIDATED (verified != no) claims that the plan
    does NOT cite, grouped by research agent, so the author can deliberately decide
    to work each into a slide, add a slide, or leave it out as duplication or not
    relevant. This never fails the gate; it is a review report, printed to stdout.
    Coverage is a judgement call, but sourced material must not be dropped silently."""
    plan = _load_plan(plan_path)
    ledger = _load_ledger(ledger_path)
    cited = set()
    for s in plan.get("slides", []):
        for c in s.get("claim_ids", []) or []:
            cited.add(c)
    for _, c in _iter_cells(plan):
        for cid in c.get("claim_ids", []) or []:
            cited.add(cid)
    verified = {cid: r for cid, r in ledger.items() if (r.get("verified") or "").lower() != "no"}
    uncited = {cid: r for cid, r in verified.items() if cid not in cited}
    groups: dict = {}
    for cid, r in sorted(uncited.items()):
        groups.setdefault(cid.split("-")[0], []).append((cid, r))
    print(f"COVERAGE: {len(cited)} of {len(verified)} validated claims cited; "
          f"{len(uncited)} validated claims NOT yet used.")
    print("Review each cluster: work into a slide / add a slide / leave out (duplication or low relevance).")
    for g in sorted(groups):
        print(f"\n-- {g} ({len(groups[g])} uncited) --")
        for cid, r in groups[g]:
            band = r.get("confidence_band", "")
            print(f"  [{cid}] ({band}) {(r.get('claim') or '')[:120]}")
    return []  # report only; never blocks


PERSONA_MARK = re.compile(r"(?i)on the\b.{0,60}\bmind\b")  # matches "what is on the CEO's mind", etc.
PERSONA_ROLES = {
    "CEO": re.compile(r"(?i)\bCEO\b|chief executive"),
    "CSCO / Chief Supply Chain Officer": re.compile(r"(?i)\bCSCO\b|chief supply chain|supply chain officer"),
    "Head of Real Estate": re.compile(r"(?i)head of real estate|real[ -]?estate"),
}


def personas(plan_path: str) -> List[str]:
    """MANDATORY persona family. The three slides 'what is on the mind of the
    CEO / CSCO (Chief Supply Chain Officer) / Head of Real Estate' must ALWAYS be
    present in every deck (reference/deck-structure.md). Assert at least three
    'on the mind' scene slides exist and that each of the three roles is covered,
    matching only on those persona slides' eyebrow/headline so unrelated slides
    (e.g. 'CHALLENGE TO REAL ESTATE') cannot satisfy the check."""
    plan = _load_plan(plan_path)
    mind = []
    for s in plan.get("slides", []):
        if s.get("kind", "scene") != "scene":
            continue
        hay = " ".join([str(s.get("eyebrow") or ""), str(s.get("headline") or "")])
        if PERSONA_MARK.search(hay):
            mind.append(hay)
    defects: List[str] = []
    if len(mind) < 3:
        defects.append(f"found {len(mind)} 'what is on the mind' persona slides; the three "
                       "(CEO, CSCO, Head of Real Estate) are mandatory and must always be present")
    joined = " || ".join(mind)
    for role, rx in PERSONA_ROLES.items():
        if not rx.search(joined):
            defects.append(f"mandatory persona set is missing the '{role}' slide")
    return defects


def _answer_locations(plan: dict) -> dict:
    """Map each answer-id to the slides that BOTH tag it (slide- or cell-level
    `answers`) AND carry real content, so a bare tag on an empty slide cannot satisfy
    the contract. A slide-level tag counts when the slide has at least one populated
    content cell; a cell-level tag counts when that cell itself is populated."""
    locs: dict = {}
    for s in plan.get("slides", []):
        no = s.get("slide_no", "?")
        cells = [c for r in s.get("scene", []) or [] for c in r.get("cells", []) or []]
        slide_has_content = any(c.get("kind") in CONTENT_KINDS and _cell_has_content(c) for c in cells)
        if slide_has_content:
            for a in s.get("answers", []) or []:
                locs.setdefault(a, []).append(no)
        for c in cells:
            if _cell_has_content(c):
                for a in c.get("answers", []) or []:
                    locs.setdefault(a, []).append(no)
    return locs


def spine(plan_path: str) -> List[str]:
    """The ANSWER CONTRACT (reference/deck-structure.md): assert every REQUIRED answer
    is carried by at least one substantive slide/cell, tagged via `answers`. This is a
    content floor, NOT a template: slide count, order and layout stay composer-led, and
    G0/G4 judge whether each answer is said well. An unknown tag fails (a typo would
    silently miss the floor). Missing EXPECTED answers print as an advisory and never
    block (the story may justify the omission; G0/G4 adjudicate). The three persona
    answers are asserted by personas()."""
    plan = _load_plan(plan_path)
    used = set()
    for s in plan.get("slides", []):
        used |= set(s.get("answers", []) or [])
        for r in s.get("scene", []) or []:
            for c in r.get("cells", []) or []:
                used |= set(c.get("answers", []) or [])
    defects: List[str] = []
    for a in sorted(used - set(ALL_ANSWERS)):
        defects.append(f"unknown answer-id '{a}' tagged (not in the answer contract; typo?)")
    locs = _answer_locations(plan)
    for a in REQUIRED_ANSWERS:
        if a not in locs:
            defects.append(f"answer contract: required answer '{a}' is carried by no substantive "
                           "slide; tag the slide or cell that lands it via `answers` (or add it)")
    missing_expected = [a for a in EXPECTED_ANSWERS if a not in locs]
    if missing_expected:
        print(f"spine: advisory: expected answers absent {missing_expected}; acceptable only if the "
              "story justifies it (G0/G4 adjudicate).")
    return defects


def _run(name: str, defects: List[str]) -> int:
    if defects:
        print(f"{name}: FAIL ({len(defects)} defects)")
        for d in defects:
            print("  -", d)
        return 1
    print(f"{name}: PASS")
    return 0


def main() -> None:
    p = argparse.ArgumentParser(description="Mechanical gate checks (v6).")
    sub = p.add_subparsers(dest="cmd", required=True)
    vp = sub.add_parser("validate-plan"); vp.add_argument("plan"); vp.add_argument("schema")
    sc = sub.add_parser("self-check"); sc.add_argument("schema"); sc.add_argument("build_deck")
    a1 = sub.add_parser("qa1"); a1.add_argument("plan"); a1.add_argument("ledger")
    a2 = sub.add_parser("qa2"); a2.add_argument("plan")
    dn = sub.add_parser("density"); dn.add_argument("plan")
    pe = sub.add_parser("personas"); pe.add_argument("plan")
    sn = sub.add_parser("spine"); sn.add_argument("plan")
    cv = sub.add_parser("coverage"); cv.add_argument("plan"); cv.add_argument("ledger")
    a3 = sub.add_parser("qa3"); a3.add_argument("plan"); a3.add_argument("worklog")
    rc = sub.add_parser("reconcile"); rc.add_argument("plan"); rc.add_argument("deck_text"); rc.add_argument("ledger")
    a4 = sub.add_parser("qa4"); a4.add_argument("deck_text")
    rv = sub.add_parser("reviews"); rv.add_argument("dir"); rv.add_argument("gate", choices=["1", "2"])
    a = p.parse_args()

    if a.cmd == "validate-plan":
        sys.exit(_run("Validate-plan", validate_plan(a.plan, a.schema)))
    if a.cmd == "self-check":
        sys.exit(_run("Self-check (doc/code drift)", self_check(a.schema, a.build_deck)))
    if a.cmd == "qa1":
        sys.exit(_run("QA1 source-integrity", qa1(a.plan, a.ledger)))
    if a.cmd == "qa2":
        sys.exit(_run("QA2 evidence-and-honesty", qa2(a.plan)))
    if a.cmd == "density":
        sys.exit(_run("Density", density(a.plan)))
    if a.cmd == "personas":
        sys.exit(_run("Persona family (CEO / CSCO / Head of Real Estate)", personas(a.plan)))
    if a.cmd == "spine":
        sys.exit(_run("Answer contract (spine)", spine(a.plan)))
    if a.cmd == "coverage":
        coverage(a.plan, a.ledger); sys.exit(0)
    if a.cmd == "qa3":
        sys.exit(_run("QA3 forecasting (optional module)", qa3(a.plan, a.worklog)))
    if a.cmd == "reconcile":
        sys.exit(_run("Reconciliation", reconcile(a.plan, a.deck_text, a.ledger)))
    if a.cmd == "qa4":
        sys.exit(_run("QA4 editorial (dash sweep)", qa4(a.deck_text)))
    if a.cmd == "reviews":
        sys.exit(_run(f"Reviewer verdicts (gate {a.gate})", reviews(a.dir, a.gate)))


if __name__ == "__main__":
    main()
